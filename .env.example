# GP Solutions Pro — Environment Variables
# Copy to .env.local and fill in. Never commit .env files (covered by .gitignore).

# ── Supabase ────────────────────────────────────────────────────────────────
# Public client keys (safe to ship to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Server-only. Used by server routes/server actions for trusted operations.
# NEVER prefix with NEXT_PUBLIC_. Treat like a root password.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# ── Stripe (server-only) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
# Set in Stripe dashboard when adding the /api/payments/webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe publishable key (safe to ship to the browser).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ── Twilio (server-only) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15555550123

# ── App config ──────────────────────────────────────────────────────────────
# Public site URL — used for absolute redirects, emails, webhook URLs.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
